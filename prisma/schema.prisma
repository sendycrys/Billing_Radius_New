generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User System (Admin/Staff)
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  STAFF
}

// Customer Management
model Customer {
  id            String   @id @default(cuid())
  customer_code String   @unique
  name          String
  email         String?  @unique
  phone         String?
  address       String?
  status        CustomerStatus @default(ACTIVE)
  
  subscriptions Subscription[]
  radius_users  RadiusUser[]
  invoices      Invoice[]
  tickets       Ticket[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

// Package Management
model Package {
  id      String @id @default(cuid())
  name    String
  speed   Int    // In Mbps
  price   Float
  profile String // Radius Profile Name

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id           String   @id @default(cuid())
  customer_id  String
  package_id   String
  start_date   DateTime
  expired_date DateTime?
  status       SubStatus @default(ACTIVE)

  customer     Customer @relation(fields: [customer_id], references: [id])
  package      Package  @relation(fields: [package_id], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum SubStatus {
  ACTIVE
  INACTIVE
}

// Radius Management (Syncs with FreeRADIUS)
model RadiusUser {
  id          String @id @default(cuid())
  customer_id String
  username    String @unique
  password    String // Digunakan untuk sync ke radcheck
  profile     String // Radius Profile Name

  customer    Customer @relation(fields: [customer_id], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// FreeRADIUS Standard Tables 
// (Nama tabel dan kolom menggunakan standar FreeRADIUS)
model radcheck {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @db.VarChar(2) @default("==")
  value     String @db.VarChar(253)

  @@index([username])
}

model radreply {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @db.VarChar(2) @default("=")
  value     String @db.VarChar(253)

  @@index([username])
}

model radacct {
  radacctid        BigInt    @id @default(autoincrement())
  acctsessionid    String    @db.VarChar(64)
  acctuniqueid     String    @db.VarChar(32) @unique
  username         String?   @db.VarChar(64)
  groupname        String?   @db.VarChar(64)
  realm            String?   @db.VarChar(64)
  nasipaddress     String    @db.VarChar(15)
  nasportid        String?   @db.VarChar(32)
  nasporttype      String?   @db.VarChar(32)
  acctstarttime    DateTime?
  acctupdatetime   DateTime?
  acctstoptime     DateTime?
  acctinterval     Int?
  acctsessiontime  Int?
  acctauthentic    String?   @db.VarChar(32)
  connectinfo_start String?  @db.VarChar(50)
  connectinfo_stop  String?  @db.VarChar(50)
  acctinputoctets  BigInt?
  acctoutputoctets BigInt?
  calledstationid  String?   @db.VarChar(50)
  callingstationid String?   @db.VarChar(50)
  acctterminatecause String? @db.VarChar(32)
  servicetype      String?   @db.VarChar(32)
  framedprotocol   String?   @db.VarChar(32)
  framedipaddress  String?   @db.VarChar(15)

  @@index([username])
  @@index([acctstarttime])
  @@index([acctstoptime])
  @@index([nasipaddress])
}

// Billing Engine
model Invoice {
  id             String   @id @default(cuid())
  customer_id    String
  invoice_number String   @unique
  amount         Float
  due_date       DateTime
  status         InvoiceStatus @default(UNPAID)

  customer       Customer @relation(fields: [customer_id], references: [id])
  payments       Payment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id             String   @id @default(cuid())
  invoice_id     String
  payment_method String   // Contoh: Midtrans, Manual
  amount         Float
  paid_at        DateTime @default(now())

  invoice        Invoice  @relation(fields: [invoice_id], references: [id])
}

model Ticket {
  id          String   @id @default(cuid())
  customer_id String
  subject     String
  status      TicketStatus @default(OPEN)

  customer    Customer @relation(fields: [customer_id], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
